{
  "name": "@cloudasset/electron",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && tsc -p tsconfig.json && electron .\"",
    "build:web": "vite build",
    "build:tsc": "tsc -p tsconfig.json",
    "build": "pnpm build:web && pnpm build:tsc",
    "dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@cloudasset/web": "workspace:*",
    "@types/node": "^22.7.4",
    "concurrently": "^9.0.1",
    "electron": "^32.1.0",
    "electron-builder": "^25.0.5",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}
