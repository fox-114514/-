# Server
PORT=3000
NODE_ENV=development
API_KEY=change-me-to-a-strong-random-key
DB_PATH=./data/cloudasset.db
STORAGE_ROOT=./files
PUBLIC_BASE_URL=http://localhost:18080
LOG_LEVEL=info
MAX_UPLOAD_MB=512

# Production image deployment (docker-compose.prod.yml)
CLOUDASSET_SERVER_IMAGE=ghcr.io/<owner>/<repo>-server:main
CLOUDASSET_WEB_IMAGE=ghcr.io/<owner>/<repo>-web:main
WEB_PORT=18080
